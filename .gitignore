# =============================
# UNREAL ENGINE 5 - .gitignore
# =============================

# Binarios compilados
Binaries/
Build/
Intermediate/
Saved/
DerivedDataCache/

# Plugins compilados
Plugins/**/Binaries/
Plugins/**/Intermediate/

# Assets binarios del Content (son tuyos pero Git no maneja bien binarios)
# Git LFS es la solución correcta para estos, por ahora los ignoramos
Content/

# Archivos de Visual Studio
.vs/
*.sln
*.suo
*.user
*.sdf
*.opensdf
*.VC.db
*.VC.opendb

# Archivos generados por el editor
*.xcodeproj
*.xcworkspace

# Config local del editor (no del proyecto)
Config/UserSettings.ini
Config/DefaultEditor.ini

# Archivos de caché
*.VC.db
*_BuiltData.uasset
ShaderCompileWorker.*

# Logs y crashes
*.log

# Archivos de sistema
Thumbs.db
.DS_Store
